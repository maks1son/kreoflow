# Public browser configuration. Never put SUPABASE_SERVICE_ROLE_KEY here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Public PostHog browser configuration. The project token is not a secret.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_public_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Server-only key for the explicit live ad compiler path. Never expose it with NEXT_PUBLIC_.
# Live compiler default: gpt-5.6-terra with medium reasoning effort.
OPENAI_API_KEY=
